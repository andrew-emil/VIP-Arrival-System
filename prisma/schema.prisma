generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    ADMIN
    OPERATOR
    MANAGER
    OBSERVER
    GATE_GUARD
}

enum SessionStatus {
    REGISTERED
    APPROACHING
    ARRIVED
    CONFIRMED
    COMPLETED
    REJECTED
}

enum CameraRole {
    APPROACH
    GATE
}

model Event {
    id        String   @id @default(uuid())
    name      String
    startTime DateTime
    endTime   DateTime
    status    String
    window    Int      @default(480)

    createdAt DateTime @default(now())

    vips       vip[]
    cameras    Camera[]
    sessions   vipSession[]
    plateReads PlateEvent[]
}

model vip {
    id            String  @id @default(uuid())
    name          String
    company       String?
    protocolLevel String?
    notes         String?
    photoUrl      String?

    eventId String
    event   Event  @relation(fields: [eventId], references: [id])

    plates   Plate[]
    sessions vipSession[]

    createdAt DateTime @default(now())
}

model Plate {
    id          String @id @default(uuid())
    plateNumber String

    vipId String
    vip   vip    @relation(fields: [vipId], references: [id])

    @@unique([plateNumber])
}

model Camera {
    id       String  @id @default(uuid())
    name     String
    location String?
    ip       String  @unique

    role CameraRole

    lastSeen DateTime?

    eventId String
    event   Event  @relation(fields: [eventId], references: [id])

    plateReads     PlateEvent[]
    deviceAccounts DeviceAccount[]
}

model PlateEvent {
    id             String   @id @default(uuid())
    plate          String
    confidence     Float?
    cameraId       String
    timestamp      DateTime
    idempotencyKey String
    isLate         Boolean  @default(false)

    eventId String
    event   Event  @relation(fields: [eventId], references: [id])

    camera Camera @relation(fields: [cameraId], references: [id])

    createdAt DateTime @default(now())

    @@unique([idempotencyKey])
    @@index([plate])
    @@index([timestamp])
    @@index([eventId])
}

model vipSession {
    id String @id @default(uuid())

    vipId String
    vip   vip    @relation(fields: [vipId], references: [id])

    eventId String
    event   Event  @relation(fields: [eventId], references: [id])

    status SessionStatus

    approachAt  DateTime?
    arrivedAt   DateTime?
    confirmedAt DateTime?
    completedAt DateTime?
    rejectedAt  DateTime?

    confirmedBy String?
    completedBy String?
    rejectedBy  String?

    createdAt DateTime @default(now())
}

model User {
    id           String @id @default(uuid())
    name         String
    email        String @unique
    passwordHash String
    role         Role

    isActive Boolean @default(true)

    createdAt DateTime @default(now())

    permissions UserPermission[]
    auditLogs   AuditLog[]
}

model UserPermission {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    permission String
    grantedBy  String
    eventId    String?
    createdAt  DateTime @default(now())

    @@index([userId])
}

model DeviceAccount {
    id       String @id @default(uuid())
    name     String
    deviceId String @unique

    cameraId String
    camera   Camera @relation(fields: [cameraId], references: [id])

    temporaryPassword String?

    isActive Boolean @default(true)

    createdAt DateTime @default(now())
}

model AuditLog {
    id String @id @default(uuid())

    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    action String
    meta   Json?

    createdAt DateTime @default(now())
}
