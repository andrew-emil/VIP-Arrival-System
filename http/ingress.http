@baseUrl = http://localhost:3000
@apiKey = CHANGE_ME

### Receive Plate Read (Async via BullMQ)
# Returns 202 Accepted immediately. Processing happens in background.
POST {{baseUrl}}/ingress/plate-reads
x-api-key: {{apiKey}}
Content-Type: application/json

{
    "plate": "VIP-777",
    "cameraId": "cam_approach_1",
