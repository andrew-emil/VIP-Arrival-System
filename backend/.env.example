# ==============================
# Application
# ==============================
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"

# ==============================
# Database (PostgreSQL)
# ==============================
# Used by Prisma (host machine → Docker Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vas

# ==============================
# Security
# ==============================
# API key required for all endpoints except /health and /docs
# Replace with a secure value in your real .env
API_KEY=CHANGE_ME
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_SECURE_STRING
CAMERA_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
BCRYPT_ROUNDS=12

# ==============================
# PostgreSQL (Docker)
# ==============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vas
POSTGRES_PORT=5432

# ==============================
# Redis (BullMQ / Queue)
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================
# Default Admin User
# ==============================
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=your_secure_password
